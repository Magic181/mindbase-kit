# Django
DJANGO_SECRET_KEY=dev-secret-key-change-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database: USE_SQLITE=true 使用 SQLite；设为 false 并配置 MYSQL_* 使用 MySQL
USE_SQLITE=false
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=ai_notebook
MYSQL_USER=root
MYSQL_PASSWORD=your-mysql-password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT (dev: 5min access; prod: set JWT_ACCESS_TOKEN_MINUTES=120)
JWT_ACCESS_TOKEN_MINUTES=5
JWT_REFRESH_TOKEN_DAYS=7

# Celery (CELERY_TASK_ALWAYS_EAGER=true 无需单独启动 worker)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_TASK_ALWAYS_EAGER=true
MAX_UPLOAD_SIZE_MB=20

# AI (optional)
OPENAI_API_KEY=
