# Django
DJANGO_SECRET_KEY=dev-secret-key-change-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database: default to SQLite for local quick start.
# Set USE_SQLITE=false and configure MYSQL_* to use MySQL.
USE_SQLITE=true
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=ai_notebook
MYSQL_USER=ai_notebook
MYSQL_PASSWORD=dev-password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT (dev: 5min access; prod: set JWT_ACCESS_TOKEN_MINUTES=120)
JWT_ACCESS_TOKEN_MINUTES=5
JWT_REFRESH_TOKEN_DAYS=7

# Celery (CELERY_TASK_ALWAYS_EAGER=true 无需单独启动 worker)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_TASK_ALWAYS_EAGER=true
MAX_UPLOAD_SIZE_MB=20

# DeepSeek (OpenAI compatible)
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_API_KEY=

# Tavily web search (optional)
TAVILY_API_KEY=
TAVILY_MAX_RESULTS=5
TAVILY_SEARCH_DEPTH=basic

# RAG
RAG_TOP_K=5
RAG_MAX_CONTEXT_CHARS=8000
