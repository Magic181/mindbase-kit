# Django
DJANGO_SECRET_KEY=dev-secret-key-change-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Database: default to SQLite for local quick start.
# Set USE_SQLITE=false and configure MYSQL_* to use MySQL.
USE_SQLITE=true
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=ai_notebook
MYSQL_USER=ai_notebook
MYSQL_PASSWORD=dev-password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT (dev: 5min access; prod: set JWT_ACCESS_TOKEN_MINUTES=120)
JWT_ACCESS_TOKEN_MINUTES=5
JWT_REFRESH_TOKEN_DAYS=7

# Celery (CELERY_TASK_ALWAYS_EAGER=true 无需单独启动 worker)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_TASK_ALWAYS_EAGER=true
MAX_UPLOAD_SIZE_MB=20

# DeepSeek (OpenAI compatible)
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_API_KEY=
DEEPSEEK_TIMEOUT_SECONDS=60
DEEPSEEK_MAX_RETRIES=2
DEEPSEEK_RETRY_BACKOFF_SECONDS=0.2

# Tavily web search (optional)
TAVILY_API_KEY=
TAVILY_MAX_RESULTS=5
TAVILY_SEARCH_DEPTH=basic
TAVILY_TIMEOUT_SECONDS=20
TAVILY_MAX_RETRIES=1
TAVILY_RETRY_BACKOFF_SECONDS=0.2

# Image OCR (optional)
OCR_ENABLED=true
OCR_TESSERACT_CMD=tesseract
OCR_LANG=chi_sim+eng
OCR_TIMEOUT_SECONDS=30

# Vision captions (optional)
# VISION_PROVIDER=openai_compatible also supports OpenAI-style multimodal endpoints.
# VISION_PROVIDER=zhipu uses GLM visual models such as glm-4.6v-flashx.
VISION_ENABLED=false
VISION_PROVIDER=openai_compatible
VISION_API_KEY=
VISION_BASE_URL=https://api.openai.com/v1
VISION_MODEL=gpt-4o-mini
VISION_TIMEOUT_SECONDS=60
VISION_RETRY_ATTEMPTS=2
VISION_RETRY_BACKOFF_SECONDS=1
VISION_FALLBACK_MODELS=
VISION_THINKING=
VISION_PROMPT=

# RAG
RAG_TOP_K=5
RAG_MAX_CONTEXT_CHARS=8000
